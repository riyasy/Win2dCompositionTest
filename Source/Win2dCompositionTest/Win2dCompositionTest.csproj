<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<OutputType>WinExe</OutputType>
		<TargetFramework>net8.0-windows10.0.22621.0</TargetFramework>
		<TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
		<RootNamespace>Win2dCompositionTest</RootNamespace>
		<ApplicationManifest>app.manifest</ApplicationManifest>
		<Platforms>x86;x64;ARM64</Platforms>
		<RuntimeIdentifiers>win-x86;win-x64;win-arm64</RuntimeIdentifiers>
		<PublishProfile>win-$(Platform).pubxml</PublishProfile>
		<UseWinUI>true</UseWinUI>
		<WinUISDKReferences>false</WinUISDKReferences>
		<EnableMsixTooling>true</EnableMsixTooling>
		<PublishAot>true</PublishAot>
		<DefaultLanguage>en-US</DefaultLanguage>
		<WindowsPackageType>None</WindowsPackageType>
		<WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
		<Nullable>enable</Nullable>
	</PropertyGroup>


	<ItemGroup>
		<Content Include="Assets\SplashScreen.scale-200.png" />
		<Content Include="Assets\LockScreenLogo.scale-200.png" />
		<Content Include="Assets\Square150x150Logo.scale-200.png" />
		<Content Include="Assets\Square44x44Logo.scale-200.png" />
		<Content Include="Assets\Square44x44Logo.targetsize-24_altform-unplated.png" />
		<Content Include="Assets\StoreLogo.png" />
		<Content Include="Assets\Wide310x150Logo.scale-200.png" />
	</ItemGroup>

	<ItemGroup>
		<Manifest Include="$(ApplicationManifest)" />
	</ItemGroup>

	<!--
    Defining the "Msix" ProjectCapability here allows the Single-project MSIX Packaging
    Tools extension to be activated for this project even if the Windows App SDK Nuget
    package has not yet been restored.
  -->
	<ItemGroup Condition="'$(DisableMsixProjectCapabilityAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
		<ProjectCapability Include="Msix" />
	</ItemGroup>
	<ItemGroup>
		<PackageReference Include="Microsoft.Graphics.Win2D" Version="1.4.0" />
		<!-- Use a stable BuildTools version compatible with 1.6 -->
		<PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.1839" />
		<!-- The specific version you requested -->
		<PackageReference Include="Microsoft.WindowsAppSDK" Version="2.0.1" />
	</ItemGroup>
	<ItemGroup>
	  <Page Update="MainWindow.xaml">
	    <Generator>MSBuild:Compile</Generator>
	  </Page>
	</ItemGroup>

	<Target Name="RemoveAIMLFiles" AfterTargets="Publish">
		<ItemGroup>
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.AI.MachineLearning.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.AI.Imaging.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.AI.Text.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.AI.ContentSafety.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Workloads.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Workloads.Resources.dll" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Workloads.Resources_ec.dll" />
			<_FilesToRemove Include="$(PublishDir)onnxruntime.dll" />
			<_FilesToRemove Include="$(PublishDir)DirectML.dll" />
			<_FilesToRemove Include="$(PublishDir)NPUDetect.dll" />
			<_FilesToRemove Include="$(PublishDir)workloads.*.json" />
			<_FilesToRemove Include="$(PublishDir)workloads.json" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.AI.*.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Internal.AI.*.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.SemanticSearch*.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Internal.SemanticSearch.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Vision*.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.VisionInternal.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Internal.Vision.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.ImageCreationInternal.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Internal.ImageCreation.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Graphics.ImagingInternal.ImageObjectRemover.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Workloads*.winmd" />
			<_FilesToRemove Include="$(PublishDir)Microsoft.Windows.Workloads*.pri" />
		</ItemGroup>
		<Delete Files="@(_FilesToRemove)" />
		<RemoveDir Directories="$(PublishDir)NpuDetect" />
	</Target>


	<!--
    Defining the "HasPackageAndPublishMenuAddedByProject" property here allows the Solution
    Explorer "Package and Publish" context menu entry to be enabled for this project even if
    the Windows App SDK Nuget package has not yet been restored.
  -->
	<PropertyGroup Condition="'$(DisableHasPackageAndPublishMenuAddedByProject)'!='true' and '$(EnableMsixTooling)'=='true'">
		<HasPackageAndPublishMenu>true</HasPackageAndPublishMenu>
	</PropertyGroup>

	<!-- Publish Properties -->
	<PropertyGroup>
		<PublishReadyToRun Condition="'$(Configuration)' == 'Debug'">False</PublishReadyToRun>
		<PublishReadyToRun Condition="'$(Configuration)' != 'Debug'">True</PublishReadyToRun>
		<PublishTrimmed Condition="'$(Configuration)' == 'Debug'">False</PublishTrimmed>
		<PublishTrimmed Condition="'$(Configuration)' != 'Debug'">True</PublishTrimmed>
	</PropertyGroup>
</Project>
